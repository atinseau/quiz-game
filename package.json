{
  "name": "quiz-app",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' --parallel dev",
    "build": "bun --filter '*' --parallel build",
    "check-types": "bun --filter '*' check-types",
    "test": "bun --filter '*' test",
    "e2e": "bun --filter '@quiz-app/client' e2e",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "fclean": "rm -rf node_modules bun.lock apps/*/node_modules apps/*/dist"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@evilmartians/lefthook": "^2.1.5"
  }
}
